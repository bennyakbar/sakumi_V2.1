digraph G {
  label="OPERATIONAL_HANDBOOK_EN.md - diagram 7";
  labelloc="t";
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  bgcolor="white";
  node [fontname="Arial", fontsize=10, style="rounded,filled", fillcolor="#f8fafc", color="#334155"];
  edge [fontname="Arial", fontsize=9, color="#475569"];
  "A" [label="Create Expense Entry", shape=box];
  "B" [label="Select fee type with subcategory", shape=box];
  "C" [label="Enter: date, method, vendor, amount, description", shape=box];
  "D" [label="Status: draft", shape=box];
  "E" [label="Approve?", shape=diamond];
  "F" [label="ExpenseManagementService::approveAndPost", shape=box];
  "G" [label="DB::transaction", shape=box];
  "H" [label="TransactionService::createExpense", shape=box];
  "I" [label="Create Transaction: type=expense, number=NK-YYYY-XXXXXX", shape=box];
  "J" [label="Update expense: status=posted, posted_transaction_id", shape=box];
  "K" [label="Record approved_by, approved_at", shape=box];
  "L" [label="Status: cancelled", shape=box];
  "M" [label="Budget Management", shape=box];
  "N" [label="Set monthly budget per subcategory", shape=box];
  "O" [label="Budget vs Realization Report", shape=box];
  "P" [label="Planned vs SUM posted expenses", shape=box];
  "Q" [label="Variance = planned - realized", shape=box];
  "A" -> "B";
  "B" -> "C";
  "C" -> "D";
  "D" -> "E";
  "E" -> "F" [label="Yes"];
  "F" -> "G";
  "G" -> "H";
  "H" -> "I";
  "I" -> "J";
  "J" -> "K";
  "E" -> "L" [label="Cancel"];
  "M" -> "N";
  "N" -> "O";
  "O" -> "P";
  "P" -> "Q";
}
