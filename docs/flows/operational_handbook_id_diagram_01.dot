digraph G {
  label="OPERATIONAL_HANDBOOK_ID.md - diagram 1";
  labelloc="t";
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  bgcolor="white";
  node [fontname="Arial", fontsize=10, style="rounded,filled", fillcolor="#f8fafc", color="#334155"];
  edge [fontname="Arial", fontsize=9, color="#475569"];
  subgraph "cluster_Yayasan" {
    label="Yayasan";
    color="#cbd5e1";
    style="rounded";
    "BND" [label="Bendahara", shape=box];
    "SA" [label="Super Admin", shape=box];
  }
  subgraph "cluster_Unit" {
    label="Unit Sekolah";
    color="#cbd5e1";
    style="rounded";
    "DTA" [label="Unit DTA", shape=box];
    "MI" [label="Unit MI", shape=box];
    "RA" [label="Unit RA", shape=box];
  }
  subgraph "cluster_Modul" {
    label="Modul Utama";
    color="#cbd5e1";
    style="rounded";
    "ADM" [label="Penerimaan / PSB", shape=box];
    "BNK" [label="Rekonsiliasi Bank", shape=box];
    "EXP" [label="Pengeluaran", shape=box];
    "INV" [label="Penagihan", shape=box];
    "MST" [label="Data Master", shape=box];
    "RPT" [label="Laporan", shape=box];
    "STL" [label="Pembayaran", shape=box];
    "TXN" [label="Transaksi", shape=box];
  }
  subgraph "cluster_Data" {
    label="Catatan Keuangan";
    color="#cbd5e1";
    style="rounded";
    "AUD" [label="Log Audit", shape=box];
    "OBL" [label="Kewajiban Siswa", shape=box];
    "RCP" [label="Kuitansi", shape=box];
  }
  "Modul" [label="Modul", shape=box];
  "Unit" [label="Unit", shape=box];
  "SA" -> "Unit" [label="mengelola"];
  "SA" -> "Modul" [label="mengonfigurasi"];
  "BND" -> "INV" [label="mengawasi"];
  "BND" -> "STL" [label="mengawasi"];
  "BND" -> "EXP" [label="mengawasi"];
  "BND" -> "BNK" [label="mengawasi"];
  "MI" -> "ADM";
  "MI" -> "MST";
  "RA" -> "ADM";
  "RA" -> "MST";
  "DTA" -> "ADM";
  "DTA" -> "MST";
  "ADM" -> "MST" [label="pendaftaran"];
  "MST" -> "OBL" [label="pemetaan biaya"];
  "OBL" -> "INV" [label="menghasilkan"];
  "INV" -> "STL" [label="pembayaran"];
  "STL" -> "RCP" [label="menerbitkan"];
  "TXN" -> "RCP" [label="menerbitkan"];
  "EXP" -> "TXN" [label="posting"];
  "INV" -> "RPT";
  "STL" -> "RPT";
  "TXN" -> "RPT";
  "EXP" -> "RPT";
  "BNK" -> "TXN" [label="mencocokkan"];
  "Modul" -> "AUD";
}
