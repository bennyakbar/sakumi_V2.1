digraph G {
  label="OPERATIONAL_HANDBOOK.md - diagram 8";
  labelloc="t";
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  bgcolor="white";
  node [fontname="Arial", fontsize=10, style="rounded,filled", fillcolor="#f8fafc", color="#334155"];
  edge [fontname="Arial", fontsize=9, color="#475569"];
  subgraph "cluster_sg_1" {
    label="Audit Log";
    color="#cbd5e1";
    style="rounded";
    "B" [label="Enter bank name, period, opening balance", shape=box];
    "C" [label="Import CSV bank statement", shape=box];
    "H" [label="Line status: matched", shape=box];
    "K" [label="Line status: unmatched", shape=box];
    "M" [label="Close Session", shape=box];
    "O" [label="Log: create_session", shape=box];
    "P" [label="Log: import_csv + row count", shape=box];
    "Q" [label="Log: match_line", shape=box];
    "R" [label="Log: unmatch_line", shape=box];
    "S" [label="Log: close_session", shape=box];
  }
  "A" [label="Create Session", shape=box];
  "D" [label="Lines created: unmatched", shape=box];
  "E" [label="For each line", shape=diamond];
  "F" [label="Select system transaction to match", shape=box];
  "G" [label="Transaction valid?", shape=diamond];
  "I" [label="Error: invalid transaction", shape=box];
  "J" [label="Need to unmatch?", shape=diamond];
  "L" [label="All lines matched?", shape=diamond];
  "N" [label="Session read-only", shape=box];
  "A" -> "B" [label="status: draft"];
  "B" -> "C";
  "C" -> "D" [label="status: in_review"];
  "D" -> "E";
  "E" -> "F";
  "F" -> "G";
  "G" -> "H" [label="completed + same unit"];
  "G" -> "I" [label="invalid"];
  "H" -> "J";
  "J" -> "K" [label="Yes"];
  "K" -> "E";
  "J" -> "L" [label="No"];
  "L" -> "E" [label="No"];
  "L" -> "M" [label="Yes"];
  "M" -> "N" [label="status: closed"];
  "B" -> "O";
  "C" -> "P";
  "H" -> "Q";
  "K" -> "R";
  "M" -> "S";
}
