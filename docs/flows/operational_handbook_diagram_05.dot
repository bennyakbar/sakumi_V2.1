digraph G {
  label="OPERATIONAL_HANDBOOK.md - diagram 5";
  labelloc="t";
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  bgcolor="white";
  node [fontname="Arial", fontsize=10, style="rounded,filled", fillcolor="#f8fafc", color="#334155"];
  edge [fontname="Arial", fontsize=9, color="#475569"];
  subgraph "cluster_sg_1" {
    label="View Layer";
    color="#cbd5e1";
    style="rounded";
    "T" [label="Return Response", shape=box];
    "U" [label="@can directives in Blade", shape=box];
    "V" [label="Show/hide UI elements per permission", shape=box];
  }
  "A" [label="HTTP Request", shape=box];
  "B" [label="Auth Middleware", shape=box];
  "C" [label="Redirect to Login", shape=box];
  "D" [label="SetLocale Middleware", shape=box];
  "E" [label="EnsureUnitContext Middleware", shape=box];
  "F" [label="Set current_unit_id in session", shape=box];
  "G" [label="CheckInactivity Middleware", shape=box];
  "H" [label="Logout + Redirect", shape=box];
  "I" [label="Route has role middleware?", shape=diamond];
  "J" [label="CheckRole Middleware", shape=box];
  "K" [label="403 Unauthorized", shape=box];
  "L" [label="Route has permission middleware?", shape=diamond];
  "M" [label="Spatie can: middleware", shape=box];
  "N" [label="Controller Action", shape=box];
  "O" [label="BelongsToUnit Global Scope", shape=box];
  "P" [label="Data filtered by current_unit_id", shape=box];
  "Q" [label="Mutation request?", shape=diamond];
  "R" [label="AuditLog Middleware", shape=box];
  "S" [label="Log: method, URL, IP, user_agent, status", shape=box];
  "A" -> "B";
  "B" -> "C" [label="Not authenticated"];
  "B" -> "D" [label="Authenticated"];
  "D" -> "E";
  "E" -> "F";
  "F" -> "G";
  "G" -> "H" [label="Timed out"];
  "G" -> "I" [label="Active"];
  "I" -> "J" [label="Yes"];
  "J" -> "K" [label="User lacks role"];
  "J" -> "L" [label="User has role"];
  "I" -> "L" [label="No"];
  "L" -> "M" [label="Yes"];
  "M" -> "K" [label="Permission denied"];
  "M" -> "N" [label="Permission granted"];
  "L" -> "N" [label="No"];
  "N" -> "O";
  "O" -> "P";
  "P" -> "Q";
  "Q" -> "R" [label="Yes"];
  "R" -> "S";
  "Q" -> "T" [label="No"];
  "S" -> "T";
  "T" -> "U";
  "U" -> "V";
}
